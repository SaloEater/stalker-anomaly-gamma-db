# Normalize all text files to LF in the blob (working tree is LF too on every OS).
# Closes the path that allowed style.css to drift to CRLF in commit 929e8c5.
* text=auto eol=lf

# Binary files — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
